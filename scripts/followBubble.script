go.property("follow_target", hash("/bubble"))

local MAIN_TARGET = hash("/bubble")

function init(self)
	self.follower = go.get_id()
	self.target = self.follow_target
	self.is_following = true
	self.can_drop = self.target == MAIN_TARGET
	msg.post("#collisionobject", "disable")
	msg.post("#veggietrigger", "enable")
	if self.can_drop then
		msg.post("main:/bubble#movebubble", "set_active", { id = self.follower })
	end
end

function final(self)

end

function update(self, dt)
	if self.is_following and self.target then
		go.set_position(go.get_position(self.target), self.follower)
	end
end

function on_message(self, message_id, message, sender)
	if message_id == hash("drop") then
		if self.can_drop then
			dropVeggie(self)
		end
	elseif message_id == hash("switch_to_main") then
		-- Slide complete: the preview bubble has carried us over the main
		-- bubble and is about to snap back to rest. Follow the main bubble
		-- from now on so the player can steer us.
		self.target = MAIN_TARGET
		self.can_drop = true
		msg.post("main:/bubble#movebubble", "set_active", { id = self.follower })
	end
end

-- Short delay before the newly-released veggie's collider activates. Prevents
-- it from immediately contacting the previously-dropped veggie when the player
-- drops two in rapid succession.
local CONTACT_DELAY = 0.15

function dropVeggie(self)
	msg.post("#veggietrigger", "disable")
	self.is_following = false
	self.can_drop = false
	self.target = nil
	-- Let the veggie start falling under gravity, then enable contact after a
	-- short delay so it has time to clear the spawn area.
	timer.delay(CONTACT_DELAY, false, function()
		msg.post("#collisionobject", "enable")
	end)
end
